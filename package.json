{
  "name": "charbot-os",
  "productName": "Charbot OS",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:buddy": "vite build --config vite.buddy.config.ts",
    "build:server": "node scripts/build-server.mjs",
    "build:all": "npm run build && npm run build:server",
    "electron:build": "node scripts/build-electron.mjs",
    "pack:ssd": "node scripts/pack-ssd.mjs",
    "pack:ssd-rpi": "node scripts/pack-ssd-rpi.mjs",
    "start": "node dist-server/server.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server dist-electron CharBotDrive-release release",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.charbot.os",
    "productName": "Charbot OS",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Charbot OS"
    },
    "npmRebuild": true
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.107",
    "@google/genai": "^1.29.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@types/multer": "^2.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "ai": "^6.0.105",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.0",
    "node-cron": "^4.2.1",
    "pdfjs-dist": "^5.4.624",
    "pdfkit": "^0.17.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "telegraf": "^4.16.3",
    "three": "^0.183.2",
    "uuid": "^13.0.0",
    "vite": "^6.2.0",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
