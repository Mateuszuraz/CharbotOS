# ─── AI API Keys ─────────────────────────────────────────────────────────────
# Set the key for whichever provider you use.
# These are configured via the Settings panel in the app; env vars are optional overrides.
GEMINI_API_KEY="YOUR_GOOGLE_GEMINI_KEY"
APP_URL="http://localhost:3000"

# ─── Vault (Storage) ─────────────────────────────────────────────────────────
# Root directory for all persistent data: uploads, logs, mobile portal, SQLite DB.
# Default: ~/CharbotVault  (created automatically on first run)
# Tip: Point this to an external SSD for large attachment storage.
CHARBOT_VAULT_DIR="/path/to/your/SSD/CharbotVault"

# Mobile portal output directory.
# Default: $CHARBOT_VAULT_DIR/mobile
CHARBOT_MOBILE_DIR="/path/to/your/SSD/CharbotVault/mobile"

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Create a bot via @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN="123456789:AABBCCDDaabbccdd..."

# Comma-separated list of Telegram chat IDs allowed to use the bot.
# Leave empty to allow ALL chats (not recommended in production).
# Find your chat ID by messaging @userinfobot.
TELEGRAM_ALLOWED_CHAT_IDS="123456789,987654321"

# ─── Discord Bot ─────────────────────────────────────────────────────────────
# Create a bot at https://discord.com/developers and paste the token here.
# Required intents: Guilds, GuildMessages, MessageContent
DISCORD_BOT_TOKEN="MTIz.abc.xyz..."

# Comma-separated list of Discord Guild (Server) IDs allowed to use the bot.
# Leave empty to allow ALL guilds (not recommended in production).
DISCORD_ALLOWED_GUILD_IDS="123456789012345678,987654321098765432"
